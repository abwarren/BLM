{
  "id": null,
  "title": "BLM V2 — UNDER Timing",
  "tags": ["blm", "under-timing", "sports"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "panels": [
    {
      "id": 1,
      "title": "UNDER Timing Score",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
      "datasource": {"uid": "prometheus"},
      "targets": [
        {"expr": "blm_under_timing_score", "legendFormat": "", "refId": "A"}
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "#4a5570", "value": null},
              {"color": "#f59e0b", "value": 15},
              {"color": "#f97316", "value": 35},
              {"color": "#22c55e", "value": 60}
            ]
          },
          "unit": "none",
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "options": {
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "values": false},
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      }
    },
    {
      "id": 2,
      "title": "Confidence",
      "type": "gauge",
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0},
      "datasource": {"uid": "prometheus"},
      "targets": [
        {"expr": "blm_under_timing_confidence", "legendFormat": "", "refId": "A"}
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "#ef4444", "value": null},
              {"color": "#f59e0b", "value": 0.3},
              {"color": "#22c55e", "value": 0.6}
            ]
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        },
        "overrides": []
      },
      "options": {
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "values": false},
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      }
    },
    {
      "id": 3,
      "title": "Status",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 0},
      "datasource": {"uid": "prometheus"},
      "targets": [
        {"expr": "blm_under_timing_status_info", "legendFormat": "", "refId": "A"}
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "#4a5570", "value": null},
              {"color": "#22c55e", "value": 0.5}
            ]
          },
          "mappings": [
            {"type": "value", "options": {"1": {"text": "PASS", "color": "#4a5570"}}}
          ]
        },
        "overrides": []
      },
      "options": {
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "values": false},
        "showThresholdLabels": false,
        "showThresholdMarkers": false,
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "id": 4,
      "title": "Total Score vs Bookmaker Line",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "datasource": {"uid": "prometheus"},
      "targets": [
        {"expr": "blm_current_total", "legendFormat": "Total Score", "refId": "A"},
        {"expr": "blm_current_line", "legendFormat": "Bookmaker Line", "refId": "B"},
        {"expr": "blm_olv", "legendFormat": "OLV", "refId": "C"}
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "lineInterpolation": "smooth",
            "lineStyle": {"fill": "solid"},
            "spanNulls": true,
            "showPoints": "never"
          }
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "Bookmaker Line"},
            "properties": [
              {"id": "custom.lineStyle", "value": {"fill": "dash", "dash": [6, 4]}}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "OLV"},
            "properties": [
              {"id": "custom.lineStyle", "value": {"fill": "dash", "dash": [10, 5]}},
              {"id": "color", "value": {"fixed": "#7c3aed"}}
            ]
          }
        ]
      },
      "options": {
        "legend": {"calcs": ["lastNotNull", "max", "min"], "displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi", "sort": "asc"},
        "stacking": {"mode": "none"}
      }
    },
    {
      "id": 5,
      "title": "Excursion from OLV & Freeze Ticks",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 12},
      "datasource": {"uid": "prometheus"},
      "targets": [
        {"expr": "blm_excursion", "legendFormat": "Excursion", "refId": "A"},
        {"expr": "blm_freeze_ticks", "legendFormat": "Freeze Ticks", "refId": "B"}
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineInterpolation": "smooth", "spanNulls": true, "showPoints": "never"},
          "unit": "none"
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "Freeze Ticks"},
            "properties": [
              {"id": "custom.axisPlacement", "value": "right"},
              {"id": "custom.lineInterpolation", "value": "stepAfter"},
              {"id": "color", "value": {"fixed": "#3b82f6"}},
              {"id": "custom.fillOpacity", "value": 20}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "Excursion"},
            "properties": [
              {"id": "color", "value": {"fixed": "#f97316"}},
              {"id": "custom.fillOpacity", "value": 15},
              {"id": "custom.axisPlacement", "value": "left"}
            ]
          }
        ]
      },
      "options": {
        "legend": {"calcs": ["lastNotNull", "max", "min"], "displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi", "sort": "none"},
        "stacking": {"mode": "none"}
      }
    },
    {
      "id": 6,
      "title": "Score & Line Delta",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 4, "x": 8, "y": 12},
      "datasource": {"uid": "prometheus"},
      "targets": [
        {"expr": "blm_score_delta", "legendFormat": "Score Δ", "refId": "A"},
        {"expr": "blm_line_delta", "legendFormat": "Line Δ", "refId": "B"},
        {"expr": "blm_is_burst", "legendFormat": "Burst", "refId": "C"}
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineInterpolation": "smooth", "spanNulls": true, "showPoints": "always", "pointSize": 3}
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "Burst"},
            "properties": [
              {"id": "custom.axisPlacement", "value": "right"},
              {"id": "custom.lineInterpolation", "value": "stepAfter"},
              {"id": "color", "value": {"fixed": "#ef4444"}},
              {"id": "custom.fillOpacity", "value": 30}
            ]
          }
        ]
      },
      "options": {
        "legend": {"calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi"},
        "stacking": {"mode": "none"}
      }
    },
    {
      "id": 7,
      "title": "UNDER Timing Score (Time Series)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 20},
      "datasource": {"uid": "prometheus"},
      "targets": [
        {"expr": "blm_under_timing_score", "legendFormat": "Score", "refId": "A"},
        {"expr": "blm_under_timing_confidence * 100", "legendFormat": "Confidence ×100", "refId": "B"}
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineInterpolation": "smooth", "spanNulls": true, "showPoints": "never"},
          "unit": "none",
          "min": 0,
          "max": 100
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "Confidence ×100"},
            "properties": [
              {"id": "custom.lineStyle", "value": {"fill": "dash", "dash": [4, 3]}},
              {"id": "color", "value": {"fixed": "#3b82f6"}},
              {"id": "custom.axisPlacement", "value": "right"}
            ]
          }
        ]
      },
      "options": {
        "legend": {"calcs": ["lastNotNull", "max", "avg"], "displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi"},
        "stacking": {"mode": "none"},
        "thresholds": [
          {"color": {"mode": "fixed", "fill": true, "line": false}, "value": null},
          {"color": {"mode": "fixed", "fill": true, "line": false}, "value": 15},
          {"color": {"mode": "fixed", "fill": true, "line": false}, "value": 35},
          {"color": {"mode": "fixed", "fill": true, "line": false}, "value": 60}
        ]
      }
    },
    {
      "id": 8,
      "title": "Component Breakdown",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 28},
      "datasource": {"uid": "prometheus"},
      "targets": [
        {"expr": "blm_under_component{component=\"historical_inflation\"}", "legendFormat": "Hist Inflation", "refId": "A"},
        {"expr": "blm_under_component{component=\"freeze\"}", "legendFormat": "Freeze", "refId": "B"},
        {"expr": "blm_under_component{component=\"burst\"}", "legendFormat": "Burst", "refId": "C"},
        {"expr": "blm_under_component{component=\"excursion\"}", "legendFormat": "Excursion", "refId": "D"},
        {"expr": "blm_under_component{component=\"divergence\"}", "legendFormat": "Divergence", "refId": "E"},
        {"expr": "blm_under_component{component=\"regression\"}", "legendFormat": "Regression", "refId": "F"},
        {"expr": "blm_under_component{component=\"under_rate\"}", "legendFormat": "Under Rate", "refId": "G"}
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "lineInterpolation": "smooth",
            "spanNulls": true,
            "showPoints": "never",
            "fillOpacity": 25
          },
          "unit": "none",
          "min": 0
        },
        "overrides": [
          {"matcher": {"id": "byName", "options": "Hist Inflation"}, "properties": [{"id": "color", "value": {"fixed": "#7c3aed"}}]},
          {"matcher": {"id": "byName", "options": "Freeze"}, "properties": [{"id": "color", "value": {"fixed": "#3b82f6"}}]},
          {"matcher": {"id": "byName", "options": "Burst"}, "properties": [{"id": "color", "value": {"fixed": "#ef4444"}}]},
          {"matcher": {"id": "byName", "options": "Excursion"}, "properties": [{"id": "color", "value": {"fixed": "#f97316"}}]},
          {"matcher": {"id": "byName", "options": "Divergence"}, "properties": [{"id": "color", "value": {"fixed": "#00d4ff"}}]},
          {"matcher": {"id": "byName", "options": "Regression"}, "properties": [{"id": "color", "value": {"fixed": "#22c55e"}}]},
          {"matcher": {"id": "byName", "options": "Under Rate"}, "properties": [{"id": "color", "value": {"fixed": "#f59e0b"}}]}
        ]
      },
      "options": {
        "legend": {"calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi"},
        "stacking": {"mode": "normal"}
      }
    },
    {
      "id": 9,
      "title": "Snapshots Processed",
      "type": "stat",
      "gridPos": {"h": 3, "w": 3, "x": 0, "y": 36},
      "datasource": {"uid": "prometheus"},
      "targets": [
        {"expr": "blm_snapshots_processed", "legendFormat": "", "refId": "A"}
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "fixed", "fixedColor": "#00d4ff"},
          "unit": "none"
        }
      },
      "options": {
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "values": false},
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 10,
      "title": "Pipeline Uptime",
      "type": "stat",
      "gridPos": {"h": 3, "w": 3, "x": 3, "y": 36},
      "datasource": {"uid": "prometheus"},
      "targets": [
        {"expr": "blm_pipeline_uptime_seconds", "legendFormat": "", "refId": "A"}
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "fixed", "fixedColor": "#22c55e"},
          "unit": "s"
        }
      },
      "options": {
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "values": false},
        "colorMode": "value",
        "graphMode": "none"
      }
    },
    {
      "id": 11,
      "title": "Hist Regression Rate",
      "type": "stat",
      "gridPos": {"h": 3, "w": 3, "x": 0, "y": 39},
      "datasource": {"uid": "prometheus"},
      "targets": [
        {"expr": "blm_historical_regression_rate", "legendFormat": "", "refId": "A"}
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "#ef4444", "value": null},
              {"color": "#f59e0b", "value": 0.3},
              {"color": "#22c55e", "value": 0.5}
            ]
          },
          "unit": "percentunit"
        }
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "values": false},
        "colorMode": "value",
        "graphMode": "none"
      }
    },
    {
      "id": 12,
      "title": "Hist Under Rate",
      "type": "stat",
      "gridPos": {"h": 3, "w": 3, "x": 3, "y": 39},
      "datasource": {"uid": "prometheus"},
      "targets": [
        {"expr": "blm_historical_under_rate", "legendFormat": "", "refId": "A"}
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "#ef4444", "value": null},
              {"color": "#f59e0b", "value": 0.35},
              {"color": "#22c55e", "value": 0.5}
            ]
          },
          "unit": "percentunit"
        }
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "values": false},
        "colorMode": "value",
        "graphMode": "none"
      }
    },
    {
      "id": 13,
      "title": "Historical Games",
      "type": "stat",
      "gridPos": {"h": 3, "w": 3, "x": 6, "y": 36},
      "datasource": {"uid": "prometheus"},
      "targets": [
        {"expr": "blm_historical_games_total", "legendFormat": "", "refId": "A"}
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "fixed", "fixedColor": "#00d4ff"},
          "unit": "none"
        }
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "values": false},
        "colorMode": "value",
        "graphMode": "none"
      }
    },
    {
      "id": 14,
      "title": "Historical Snapshots",
      "type": "stat",
      "gridPos": {"h": 3, "w": 3, "x": 6, "y": 39},
      "datasource": {"uid": "prometheus"},
      "targets": [
        {"expr": "blm_historical_snapshots_total", "legendFormat": "", "refId": "A"}
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "fixed", "fixedColor": "#f59e0b"},
          "unit": "none"
        }
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "values": false},
        "colorMode": "value",
        "graphMode": "none"
      }
    }
  ],
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {
    "refresh_intervals": ["15s", "30s", "1m", "5m", "15m", "30m", "1h"],
    "time_options": ["5m", "15m", "1h", "6h", "12h", "24h", "2d", "7d", "30d"]
  },
  "templating": {
    "list": [
      {
        "name": "league",
        "type": "constant",
        "label": "League",
        "query": "Cyber 2K26",
        "current": {"text": "Cyber 2K26", "value": "Cyber 2K26"}
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "name": "UNDER READY",
        "type": "prometheus",
        "expr": "blm_under_timing_status_info{status=\"UNDER_READY\"}",
        "enable": true,
        "iconColor": "#22c55e",
        "showIn": 0
      }
    ]
  }
}
